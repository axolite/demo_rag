# Local virtualenv and Python caches — recreated by `uv run`.
.venv/
__pycache__/
*.pyc
*.egg-info/

# The NCS v1.6.1 indexes are built locally, not committed: both resolve get_doc
# against the machine-local west clone (so a committed copy wouldn't be portable),
# and KB2 is large (~0.8–1.1 GB). Rebuild them per the runbook. nrf-bm.sqlite is
# the exception — it's small and self-contained, so it stays committed.
ncs-1.6.1-resolved.sqlite
ncs-1.6.1-source.sqlite
